generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PortfolioLink {
  id        String   @id @default(cuid())
  url       String
  platform  String
  category  String
  title     String
  tall      Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolio_links")
}
